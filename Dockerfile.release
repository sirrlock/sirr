# Dockerfile.release — used by CI with pre-built musl binaries
FROM scratch
ARG TARGETARCH
COPY dist/${TARGETARCH}/sirrd /sirrd

VOLUME ["/data"]

ENV SIRR_DATA_DIR=/data

EXPOSE 7843

ENTRYPOINT ["/sirrd"]
CMD ["serve", "--bind", "0.0.0.0:7843", "--data-dir", "/data", "--admin-socket", "/data/sirrd.sock"]
